# --- DATABASE ROUTING CONFIGURATION ---
# Fill these in to insert directly into a MySQL database
DB_HOST=localhost
DB_USER=db_user
DB_PASSWORD=YourStrongPassword123!
DB_NAME=laravel_db

# --- API ROUTING CONFIGURATION ---
# Fill this in if you want to push to your website via a REST API endpoint
API_ENDPOINT=https://yourwebsite.com/api/v1/articles
API_BEARER_TOKEN=your_secure_api_token
